{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:delta:mikael-os:learning-intake:v1",
  "title": "Learning Intake Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workspace", "isolation", "module_id", "exam_id", "exam", "source", "dedup_key", "units", "learning_objectives", "ingestion"],
  "properties": {
    "schema_version": {"const": "learning-intake.v1"},
    "workspace": {"const": "studium"},
    "isolation": {"type": "object", "additionalProperties": false, "required": ["domain", "tenant_id", "business_sources_allowed", "business_write_allowed"], "properties": {"domain": {"const": "university"}, "tenant_id": {"type": "string", "pattern": "^uni:[a-z0-9][a-z0-9._-]+$"}, "business_sources_allowed": {"const": false}, "business_write_allowed": {"const": false}}},
    "module_id": {"$ref": "#/$defs/id"},
    "exam_id": {"$ref": "#/$defs/id"},
    "exam": {"type": "object", "additionalProperties": false, "required": ["date", "form", "aids"], "properties": {"date": {"type": "string", "format": "date"}, "form": {"enum": ["written", "oral", "practical", "take_home", "other"]}, "aids": {"type": "array", "items": {"type": "object", "required": ["label", "status"], "properties": {"label": {"type": "string", "minLength": 1}, "status": {"enum": ["allowed", "forbidden", "unknown"]}}}}}},
    "source": {"type": "object", "additionalProperties": false, "required": ["scope", "format", "file_name", "intake_path", "sha256", "bytes"], "properties": {"scope": {"const": "university"}, "format": {"enum": ["pdf", "pptx"]}, "file_name": {"type": "string", "minLength": 1}, "intake_path": {"type": "string", "pattern": "^/"}, "sha256": {"$ref": "#/$defs/sha"}, "bytes": {"type": "integer", "minimum": 0}}},
    "dedup_key": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "direct_context": {"type": "object", "additionalProperties": false, "required": ["mode", "embedding_requested", "graph_write_requested", "durable_write_requested", "answer_ready", "extractor", "citations", "readable_pages", "needs_vision_pages"], "properties": {"mode": {"const": "direct_context"}, "embedding_requested": {"const": false}, "graph_write_requested": {"const": false}, "durable_write_requested": {"const": false}, "answer_ready": {"const": true}, "extractor": {"type": "string", "minLength": 1}, "citations": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}#page=[1-9][0-9]*$"}}, "readable_pages": {"type": "array", "minItems": 1, "items": {"type": "integer", "minimum": 1}}, "needs_vision_pages": {"type": "array", "items": {"type": "integer", "minimum": 1}}}},
    "units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/unit"}},
    "learning_objectives": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["objective_id", "text", "provenance_refs"], "properties": {"objective_id": {"$ref": "#/$defs/id"}, "text": {"type": "string", "minLength": 1}, "provenance_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}}}}},
    "ingestion": {"type": "object", "additionalProperties": false, "required": ["state", "history"], "properties": {"state": {"$ref": "#/$defs/state"}, "history": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["state", "at", "actor"], "properties": {"state": {"$ref": "#/$defs/state"}, "at": {"type": "string", "format": "date-time"}, "actor": {"type": "string"}}}}, "approval": {"type": "object", "required": ["approval_id", "approved_at"], "properties": {"approval_id": {"type": "string"}, "approved_at": {"type": "string", "format": "date-time"}}}}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "state": {"enum": ["dropped", "analyzing", "awaiting_confirmation", "approved", "rejected", "failed"]},
    "asset": {"type": "object", "additionalProperties": false, "required": ["asset_id", "media_type", "relative_path", "sha256"], "properties": {"asset_id": {"type": "string"}, "media_type": {"type": "string"}, "relative_path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha"}}},
    "evidence": {"type": "object", "additionalProperties": false, "required": ["kind", "producer", "content", "structured_fields", "confidence", "review_required", "authority"], "properties": {"kind": {"enum": ["native_text", "ocr", "vision"]}, "producer": {"type": "string"}, "content": {"type": "string"}, "structured_fields": {"type": "object"}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "review_required": {"type": "boolean"}, "authority": {"const": "evidence_only"}}},
    "unit": {"type": "object", "additionalProperties": false, "required": ["unit_id", "kind", "number", "citation", "source_sha256", "render_assets", "extracted_text", "evidence"], "properties": {"unit_id": {"type": "string"}, "kind": {"enum": ["page", "slide"]}, "number": {"type": "integer", "minimum": 1}, "citation": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}#(page|slide)=[1-9][0-9]*$"}, "source_sha256": {"$ref": "#/$defs/sha"}, "render_assets": {"type": "array", "items": {"$ref": "#/$defs/asset"}}, "extracted_text": {"type": "string"}, "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}}}
  }
}
